# Database (Railway PostgreSQL + pgvector)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Clerk Auth
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx

# AI
ANTHROPIC_API_KEY=sk-ant-xxx
OPENAI_API_KEY=sk-xxx

# Exa.ai
EXA_API_KEY=xxx

# Maps
NEXT_PUBLIC_MAPBOX_TOKEN=pk.xxx

# Email
RESEND_API_KEY=re_xxx

# Google Places
GOOGLE_PLACES_API_KEY=xxx

# Google Maps Embed (free, client-side — needs Maps Embed API enabled)
NEXT_PUBLIC_GOOGLE_MAPS_KEY=xxx

# Cloudflare R2
R2_ACCESS_KEY=xxx
R2_SECRET_KEY=xxx
R2_BUCKET=mydscvr-schools
R2_ENDPOINT=https://xxx.r2.cloudflarestorage.com

# Upstash Redis
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxx

# App — IMPORTANT: Set to your production domain for deployment
# Used for sitemap, robots.txt, OG metadata, and API base URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Production: NEXT_PUBLIC_APP_URL=https://mydscvr.ai
